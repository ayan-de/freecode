{
  "name": "@thisisayande/freecode-shared",
  "version": "0.2.0",
  "type": "module",
  "description": "Shared types and IPC protocol for FreeCode",
  "license": "MIT",
  "repository": "https://github.com/ayan-de/freecode",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ipc": {
      "types": "./dist/ipc/protocol.d.ts",
      "import": "./dist/ipc/protocol.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "5.9.2"
  }
}
