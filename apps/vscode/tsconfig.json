{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@thisisayande/freecode-shared": ["../../packages/shared/dist/index.d.ts"],
      "@thisisayande/freecode-shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*"]
}
