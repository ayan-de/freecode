{
  "name": "freecode",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "release": "pnpm build && pnpm publish -r --access public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/yargs": "^17.0.35",
    "prettier": "^3.7.4",
    "turbo": "^2.9.9",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "postprocessing": "^6.39.1",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "@thisisayande/freecode-shared": "workspace:*"
    }
  }
}
